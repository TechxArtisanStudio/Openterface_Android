<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/black">

    <!-- Top title bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1A1A"
        android:padding="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/keyboard_module_test"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btn_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/close_button"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Test area: simulate portrait 4-zone layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Zone 1: Shortcut strip -->
        <LinearLayout
            android:id="@+id/shortcut_strip"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#2A2A2A"
            android:paddingHorizontal="4dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/test_shortcut_bar"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Zone 2: Video area -->
        <RelativeLayout
            android:id="@+id/video_area_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#333333">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/test_video_area"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:gravity="center" />
        </RelativeLayout>

        <!-- Zone 3: Module drawer -->
        <LinearLayout
            android:id="@+id/module_drawer"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:background="#F5F5F5"
            android:visibility="visible">

            <!-- Collapse Handle -->
            <LinearLayout
                android:id="@+id/module_collapse_handle"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="#E0E0E0">

                <View
                    android:layout_width="32dp"
                    android:layout_height="4dp"
                    android:background="#999999" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/test_module_area"
                    android:textSize="10sp"
                    android:textColor="#888888"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Module Content Container -->
            <FrameLayout
                android:id="@+id/module_content_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#DDDDDD">
            </FrameLayout>
        </LinearLayout>

        <!-- Zone 4: Bottom navigation bar -->
        <LinearLayout
            android:id="@+id/module_selector_bar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:background="#1A1A1A"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/test_tab_keyboard"
                android:textColor="#888888"
                android:textSize="11sp"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/test_tab_mouse"
                android:textColor="#888888"
                android:textSize="11sp"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/test_tab_input"
                android:textColor="#888888"
                android:textSize="11sp"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/test_tab_settings"
                android:textColor="#888888"
                android:textSize="11sp"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
