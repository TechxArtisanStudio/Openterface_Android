            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="@string/Key_Slash"
            android:textColor="@color/black" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <android.widget.Button android:id="@+id/Key_RightShift"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="@string/Key_RightShift"
            android:textColor="@color/black" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
    </LinearLayout>

    <!-- Row 5: Bottom row (11 keys) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="1dp">

        <android.widget.Button android:id="@+id/Key_Ctrl"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="@string/Key_Ctrl"
            android:textColor="@color/black" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <android.widget.Button android:id="@+id/Key_Win"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="@string/Key_Win"
            android:textColor="@color/black" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <android.widget.Button android:id="@+id/Key_Alt"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="@string/Key_Alt"
            android:textColor="@color/black" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <android.widget.Button android:id="@+id/Space_Button"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="3" android:text="@string/Space_Button"
            android:textColor="@color/black" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <ImageButton android:id="@+id/Key_Up"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:src="@drawable/arrow_up" android:scaleType="centerInside"
            android:padding="4dp" tools:ignore="ContentDescription"/>

        <android.widget.Button android:id="@+id/Key_AltGr"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="@string/Key_AltGr"
            android:textColor="@color/black" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <android.widget.Button android:id="@+id/Key_CtrlGr"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="@string/Key_CtrlGr"
            android:textColor="@color/black" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <ImageButton android:id="@+id/Key_Left"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:src="@drawable/arrow_left" android:scaleType="centerInside"
            android:padding="4dp" tools:ignore="ContentDescription"/>

        <ImageButton android:id="@+id/Key_Down"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:src="@drawable/arrow_down" android:scaleType="centerInside"
            android:padding="4dp" tools:ignore="ContentDescription"/>

        <ImageButton android:id="@+id/Key_Right"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:src="@drawable/arrow_right" android:scaleType="centerInside"
            android:padding="4dp" tools:ignore="ContentDescription"/>
    </LinearLayout>

</LinearLayout>
