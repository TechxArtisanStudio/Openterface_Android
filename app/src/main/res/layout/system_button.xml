            android:theme="@style/ButtonTheme" android:layout_marginHorizontal="1dp"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

