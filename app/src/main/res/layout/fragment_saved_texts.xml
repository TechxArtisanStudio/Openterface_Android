<?xml version="1.0" encoding="utf-8"?>
<!-- Full-screen saved texts fragment -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/primary"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_close_saved_texts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?android:attr/selectableItemBackground"
            android:contentDescription="@string/saved_texts_close" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/ime_saved_text_title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/on_primary" />
    </LinearLayout>

    <!-- RecyclerView for saved texts -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_saved_texts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="@string/ime_saved_text_empty"
        android:gravity="center"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

</LinearLayout>
