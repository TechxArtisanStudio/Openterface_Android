<?xml version="1.0" encoding="utf-8"?>
<!-- Touchpad overlay layout for mouse control -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/TouchPad_View"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|center_horizontal"
    android:layout_marginBottom="8dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:visibility="gone"
    tools:context="com.openterface.AOS.activity.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- TouchPad area for mouse movement and gestures -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/touchpad_background"
            android:clipToOutline="true">

            <com.openterface.AOS.view.TouchPadView
                android:id="@+id/touchPadArea"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Scroll strip on the right side -->
            <View
                android:id="@+id/touchPadScrollStrip"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="@drawable/scroll_strip_background"
                android:contentDescription="Scroll area" />

            <!-- Brand logo at bottom center -->
            <TextView
                android:id="@+id/touchPadBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="8dp"
                android:text="Openterface"
                android:textColor="#888888"
                android:textSize="10sp"
                android:alpha="0.6" />
        </FrameLayout>

        <!-- Mouse button strip: Left - Middle - Right (hidden by default) -->
        <com.openterface.AOS.view.MouseControlStripView
            android:id="@+id/mouseButtonStrip"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
