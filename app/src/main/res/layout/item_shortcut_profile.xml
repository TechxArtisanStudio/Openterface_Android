<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/iv_profile_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_shortcut_default"
                android:background="@drawable/bg_circle_primary"
                android:padding="8dp"
                app:tint="@android:color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_shortcut_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Action Buttons -->
            <ImageButton
                android:id="@+id/btn_duplicate"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_content_copy"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="复制"
                app:tint="?attr/colorOnSurfaceVariant" />

            <ImageButton
                android:id="@+id/btn_export"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_export"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="导出"
                android:layout_marginStart="4dp"
                app:tint="?attr/colorOnSurfaceVariant" />

            <ImageButton
                android:id="@+id/btn_edit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="编辑"
                android:layout_marginStart="4dp"
                app:tint="?attr/colorOnSurfaceVariant" />

            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="删除"
                android:layout_marginStart="4dp"
                app:tint="?attr/colorError" />
        </LinearLayout>

        <!-- Description -->
        <TextView
            android:id="@+id/tv_profile_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
