<?xml version="1.0" encoding="utf-8"?>
<!-- Mouse module for portrait mode: Help button + L/M/R + Scroll Strip (horizontal) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mouse_module_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background_light"
    android:padding="12dp"
    tools:context="com.openterface.AOS.activity.MainActivity">

    <!-- Help Button (top-left, opens touchpad help dialog) -->
    <ImageButton
        android:id="@+id/btn_mouse_help"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="start"
        android:layout_marginBottom="4dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/baseline_help_24"
        android:contentDescription="Mouse help"
        android:scaleType="centerInside"
        android:tint="@color/text_secondary" />

    <!-- L/M/R buttons + Scroll Strip (horizontal, same total height as before) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:orientation="horizontal">

        <!-- Mouse Button Strip: L + M + R -->
        <com.openterface.AOS.view.MouseControlStripView
            android:id="@+id/portrait_mouseButtonStrip"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- Scroll Strip (fixed width) -->
        <com.openterface.AOS.view.BasicPortraitScrollStripView
            android:id="@+id/portrait_scroll_strip"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
