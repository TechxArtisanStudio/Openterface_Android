<?xml version="1.0" encoding="utf-8"?>
<!-- Mouse module for portrait mode: Mouse guide + scroll strip + L/M/R buttons -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mouse_module_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background_light"
    android:padding="12dp"
    tools:context="com.openterface.AOS.activity.MainActivity">

    <!-- Mouse Guide Area + Scroll Strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="horizontal">

        <!-- Mouse Guide (weight=5) -->
        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="5"
            android:background="@drawable/km_basic_mouse_guide_background"
            android:padding="12dp"
            android:layout_marginEnd="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mouse Operations"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="• Single finger move: Move cursor\n• Tap: Left click\n• Two finger scroll: Scroll wheel\n• Three finger tap: Middle click\n• Long press: Right click"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="4dp" />


            </LinearLayout>

        </ScrollView>

        <!-- Scroll Strip (weight=1) -->
        <com.openterface.AOS.view.BasicPortraitScrollStripView
            android:id="@+id/portrait_scroll_strip"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Mouse Button Strip: L + M + R -->
    <com.openterface.AOS.view.MouseControlStripView
        android:id="@+id/portrait_mouseButtonStrip"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp" />

</LinearLayout>
