<?xml version="1.0" encoding="utf-8"?>
<!-- Mouse module for portrait mode: Help button + L/M/R + Scroll Strip (horizontal) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mouse_module_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background_light"
    android:padding="12dp"
    tools:context="com.openterface.AOS.activity.MainActivity">

    <!-- Top row: Help button + Openterface logo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <ImageButton
            android:id="@+id/btn_mouse_help"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/baseline_help_24"
            android:contentDescription="Mouse help"
            android:scaleType="centerInside"
            android:tint="@color/text_secondary" />

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="16dp"
            android:src="@drawable/ic_openterface_wordmark"
            android:tint="@color/text_secondary"
            android:adjustViewBounds="true"
            tools:ignore="ContentDescription" />

        <Space
            android:layout_width="36dp"
            android:layout_height="0dp" />

    </LinearLayout>

    <!-- L/M/R buttons + Scroll Strip (horizontal, same total height as before) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:orientation="horizontal">

        <!-- Mouse Button Strip: L + M + R -->
        <com.openterface.AOS.view.MouseControlStripView
            android:id="@+id/portrait_mouseButtonStrip"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <!-- Scroll Strip (fixed width) -->
        <com.openterface.AOS.view.BasicPortraitScrollStripView
            android:id="@+id/portrait_scroll_strip"
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>
