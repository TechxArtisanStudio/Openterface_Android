<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/vnc_server"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_surface"
            android:layout_marginBottom="16dp" />

        <!-- Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_label"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/vnc_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_stopped"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/purple_500" />
        </LinearLayout>

        <!-- IP Address display (read-only) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/device_ip_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <TextView
            android:id="@+id/vnc_ip_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/loading"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Port -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/port_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <EditText
            android:id="@+id/vnc_port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="5900"
            android:layout_marginBottom="12dp" />

        <!-- Password -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/password_optional_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <EditText
            android:id="@+id/vnc_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:hint="@string/hint_no_password"
            android:layout_marginBottom="12dp" />

        <!-- Bind Address -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bind_address_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <EditText
            android:id="@+id/vnc_bind_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:text="0.0.0.0"
            android:hint="@string/hint_default_bind"
            android:layout_marginBottom="12dp" />

        <!-- Encoding -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/vnc_encoding_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <Spinner
            android:id="@+id/vnc_encoding_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- Quality Level -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/vnc_quality_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <Spinner
            android:id="@+id/vnc_quality_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <!-- Compression Level -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/vnc_compress_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <Spinner
            android:id="@+id/vnc_compress_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Auto-start toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/auto_start_on_usb"
                android:textSize="14sp" />
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/vnc_auto_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false" />
        </LinearLayout>

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/vnc_start_button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/start_server"
                android:backgroundTint="@color/green"
                android:textColor="@color/white" />
            <Button
                android:id="@+id/vnc_stop_button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/stop_server"
                android:backgroundTint="@color/purple_500"
                android:textColor="@color/white"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
