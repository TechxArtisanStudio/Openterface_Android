<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/webrtc_server"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_surface"
            android:layout_marginBottom="8dp" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/description_webrtc"
            android:textSize="12sp"
            android:textColor="@color/gray_600"
            android:layout_marginBottom="16dp" />

        <!-- Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_label"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/webrtc_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_stopped"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/purple_500" />
        </LinearLayout>

        <!-- IP Address display (read-only) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/device_ip_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <TextView
            android:id="@+id/webrtc_ip_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/loading"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- Connection URL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/browser_url_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <TextView
            android:id="@+id/webrtc_connection_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/url_placeholder"
            android:textSize="12sp"
            android:textColor="#2196F3"
            android:autoLink="web"
            android:layout_marginBottom="16dp" />

        <!-- Signaling Port -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/signaling_port_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <EditText
            android:id="@+id/webrtc_signaling_port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="8080"
            android:layout_marginBottom="12dp" />

        <!-- Video FPS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/frame_rate_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <EditText
            android:id="@+id/webrtc_fps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="30"
            android:layout_marginBottom="12dp" />

        <!-- Video Bitrate -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bitrate_label"
            android:textSize="12sp"
            android:textColor="@color/gray_600" />
        <EditText
            android:id="@+id/webrtc_bitrate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="2000"
            android:layout_marginBottom="16dp" />

        <!-- Auto-start on USB connect -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/webrtc_auto_start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_start_on_usb"
            android:textSize="14sp"
            android:checked="false"
            android:layout_marginBottom="16dp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/webrtc_start_button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/start_server"
                android:backgroundTint="@color/green"
                android:textColor="@color/white" />
            <Button
                android:id="@+id/webrtc_stop_button"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/stop_server"
                android:backgroundTint="@color/purple_500"
                android:textColor="@color/white"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Help text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/description_webrtc_howto"
            android:textSize="12sp"
            android:textColor="@color/gray_600"
            android:layout_marginTop="16dp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
