<?xml version="1.0" encoding="utf-8"?>
<!-- Shortcut Hub floating panel — dual-panel design (reference: KeyCMD ShortcutHubFragment) -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Dim overlay (tap to close) -->
    <View
        android:id="@+id/hub_dim_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true" />

    <!-- Floating card (left side) -->
    <LinearLayout
        android:id="@+id/hub_floating_card"
        android:layout_width="400dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:layout_margin="12dp"
        android:orientation="vertical"
        android:background="@color/surface_background"
        android:elevation="8dp">

        <!-- Title bar -->
        <LinearLayout
            android:id="@+id/hub_title_bar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:background="?attr/colorPrimary">

            <TextView
                android:id="@+id/hub_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/shortcut_hub_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageButton
                android:id="@+id/btn_close_hub"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/baseline_close_24"
                android:contentDescription="@string/shortcut_hub_close"
                android:tint="@android:color/white"
                tools:ignore="ContentDescription" />
        </LinearLayout>

        <!-- Content area (panels toggle here) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- ========== PANEL 1: Profile List ========== -->
            <LinearLayout
                android:id="@+id/panel_profile_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_profiles"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:paddingHorizontal="8dp" />

                <TextView
                    android:id="@+id/tv_empty_profiles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:padding="32dp"
                    android:text="@string/shortcut_hub_no_profiles"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- Bottom action bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="8dp"
                    android:background="@color/card_background">

                    <Button
                        android:id="@+id/btn_new_profile"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="@string/shortcut_hub_new"
                        android:textSize="13sp"
                        android:background="?attr/colorPrimary"
                        android:textColor="@android:color/white" />

                    <Button
                        android:id="@+id/btn_import_profile"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:text="@string/shortcut_hub_import"
                        android:textSize="13sp"
                        android:background="@color/divider"
                        android:textColor="@color/text_primary" />

                    <Button
                        android:id="@+id/btn_export_all"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="@string/shortcut_hub_export_all"
                        android:textSize="13sp"
                        android:background="@color/divider"
                        android:textColor="@color/text_primary" />
                </LinearLayout>
            </LinearLayout>

            <!-- ========== PANEL 2: Shortcut Detail ========== -->
            <LinearLayout
                android:id="@+id/panel_shortcut_detail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Detail header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="8dp"
                    android:background="@color/card_background"
                    android:elevation="2dp">

                    <ImageButton
                        android:id="@+id/btn_back_to_profiles"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_arrow_back_24"
                        android:contentDescription="@string/shortcut_hub_back"
                        android:padding="6dp"
                        android:tint="@color/text_primary"
                        tools:ignore="ContentDescription" />

                    <TextView
                        android:id="@+id/tv_detail_profile_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="4dp"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <ImageButton
                        android:id="@+id/btn_reset_profile"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_refresh_24"
                        android:contentDescription="@string/shortcut_hub_reset"
                        android:padding="6dp"
                        android:tint="@color/text_primary"
                        android:visibility="gone"
                        tools:ignore="ContentDescription" />

                    <ImageButton
                        android:id="@+id/btn_add_shortcut"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_add_24"
                        android:contentDescription="@string/shortcut_hub_add_shortcut"
                        android:padding="6dp"
                        android:tint="@color/text_primary"
                        tools:ignore="ContentDescription" />
                </LinearLayout>

                <!-- Category Tabs -->
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tab_layout_categories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/card_background"
                    app:tabGravity="start"
                    app:tabMode="scrollable"
                    app:tabIndicatorHeight="2dp"
                    app:tabIndicatorFullWidth="false"
                    app:tabTextAppearance="@style/TextAppearance.AppCompat.Body2" />

                <!-- Content: grid (favorites) or list (browse) -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_my_shortcuts"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:padding="8dp"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recycler_browse_shortcuts"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:paddingHorizontal="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="8dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_empty_shortcuts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:padding="32dp"
                        android:text="@string/shortcut_hub_no_favorites"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
