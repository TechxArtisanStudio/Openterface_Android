<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header: close | title | preview | load | send -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/header_background"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageButton
                android:id="@+id/ime_saved_text_close"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/ime_saved_text_close"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_arrow_back_24"
                android:tint="@color/text_primary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/ime_saved_text_title"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/ime_saved_text_action_preview"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/ime_saved_text_preview_cd"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_visibility_24"
                android:visibility="gone"
                android:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/ime_saved_text_action_load"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/ime_saved_text_load_cd"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_file_download_material_24"
                android:visibility="gone"
                android:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/ime_saved_text_action_send"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/ime_saved_text_send_cd"
                android:padding="6dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_send_material_24"
                android:visibility="gone"
                android:tint="@color/text_primary" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/ime_saved_text_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="true"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/ime_saved_text_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/ime_saved_text_empty"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
