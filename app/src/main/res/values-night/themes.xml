<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- 基础主题（夜间模式） -->
    <style name="Base.Theme.Usbvideo" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/theme_accent_orange</item>
        <item name="colorPrimaryContainer">@color/theme_accent_orange_container</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/theme_accent_orange</item>
        <item name="colorSecondaryContainer">@color/theme_accent_orange_container</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimary</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
    </style>

    <style name="Theme.Usbvideo" parent="Base.Theme.Usbvideo" />

