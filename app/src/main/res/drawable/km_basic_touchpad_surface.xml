<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/touchpad_background" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:startColor="@color/km_basic_touchpad_pattern_soft_light"
                android:centerColor="@android:color/transparent"
                android:endColor="@color/km_basic_touchpad_pattern_soft_light" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/km_basic_touchpad_pattern_soft_shadow"
                android:centerColor="@android:color/transparent"
                android:endColor="@color/km_basic_touchpad_pattern_soft_shadow" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.28"
                android:centerY="0.24"
                android:endColor="@android:color/transparent"
                android:gradientRadius="260dp"
                android:startColor="@color/km_basic_touchpad_pattern_glow"
                android:type="radial" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0.78"
                android:centerY="0.82"
                android:endColor="@android:color/transparent"
                android:gradientRadius="280dp"
                android:startColor="@color/km_basic_touchpad_pattern_sink"
                android:type="radial" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</layer-list>
