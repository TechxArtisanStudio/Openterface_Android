<?xml version="1.0" encoding="utf-8"?>
<!-- Shortcut strip button background: rounded rectangle with dark theme -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FF444444" />
            <stroke android:width="1dp" android:color="#FF666666" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF2A2A2A" />
            <stroke android:width="1dp" android:color="#FF555555" />
            <corners android:radius="6dp" />
        </shape>
    </item>
</selector>