<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/key_bg_pressed" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <stroke
                android:width="2dp"
                android:color="@color/primary" />
            <solid android:color="@color/key_bg_pressed" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/touchpad_background" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="45"
                        android:startColor="@color/km_basic_touchpad_pattern_soft_light"
                        android:centerColor="@android:color/transparent"
                        android:endColor="@color/km_basic_touchpad_pattern_soft_light" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:startColor="@color/km_basic_touchpad_pattern_soft_shadow"
                        android:centerColor="@android:color/transparent"
                        android:endColor="@color/km_basic_touchpad_pattern_soft_shadow" />
                    <corners android:radius="10dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
