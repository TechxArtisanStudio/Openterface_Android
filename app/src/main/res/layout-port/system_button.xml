                android:elevation="1dp"
                android:text="&amp;"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="1.5dp">
            <android.widget.Button android:id="@+id/I_Button"
