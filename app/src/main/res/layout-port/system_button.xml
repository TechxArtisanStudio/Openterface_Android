            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/X_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/X_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/X_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="&quot;"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/C_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/C_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/C_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text=";"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/V_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/V_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/V_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text=":"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/B_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/B_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/B_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="/"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/N_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/N_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/N_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="|"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/M_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/M_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/M_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="\\"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/Key_Slash"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/Key_Slash"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/Key_Slash_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="?"/>
        </FrameLayout>

        <ImageButton android:id="@+id/Enter_Button"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1.3" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme"
            android:layout_marginStart="@dimen/keyboard_key_margin_horizontal" android:layout_marginEnd="0dp"
            android:src="@drawable/arrow_return_left" android:scaleType="centerInside"
            android:padding="4dp" tools:ignore="ContentDescription"/>
    </LinearLayout>

    <!-- Row 4: FN(1.2) + Ctrl(1) + Space(3.6) + Alt(1) + Win(1.2), total=8
         Bottom modifier row. Space is wide. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal">

        <android.widget.Button android:id="@+id/Key_FN"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1.2" android:text="@string/Key_FN"
            android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme"
            android:layout_marginStart="0dp" android:layout_marginEnd="@dimen/keyboard_key_margin_horizontal"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <android.widget.Button android:id="@+id/Key_Ctrl"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="@string/Key_Ctrl"
            android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <ImageButton android:id="@+id/Space_Button"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="3.6"
            android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal"
            android:src="@drawable/space_bar_icon"
            android:scaleType="centerInside"
            android:padding="12dp"
            android:contentDescription="@string/Space_Button"
            tools:ignore="UnusedAttribute"/>

        <android.widget.Button android:id="@+id/Key_Alt"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:text="@string/Key_Alt"
            android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <android.widget.Button android:id="@+id/Key_Win"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1.2" android:text="@string/Key_Win"
            android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme"
            android:layout_marginStart="@dimen/keyboard_key_margin_horizontal" android:layout_marginEnd="0dp"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
    </LinearLayout>

</LinearLayout>
