            android:theme="@style/ButtonTheme"
            android:layout_marginStart="0dp" android:layout_marginEnd="@dimen/keyboard_key_margin_horizontal"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <FrameLayout
