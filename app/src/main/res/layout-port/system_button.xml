    </LinearLayout>

    <!-- Row 3: Shift(1.5) + Z X C V B N M /(1) + Enter(1.3), total=11.8
         Corner hints show long-press symbols for letter keys. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/keyboard_key_margin_vertical">

        <android.widget.Button android:id="@+id/Key_LeftShift"
