            <TextView android:id="@+id/D_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="-"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/F_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/F_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/F_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="+"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/G_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/G_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
