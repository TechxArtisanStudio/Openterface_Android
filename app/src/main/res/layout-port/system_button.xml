                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="/"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
