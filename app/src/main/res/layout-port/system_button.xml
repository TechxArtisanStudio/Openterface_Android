<?xml version="1.0" encoding="utf-8"?>
<!-- Portrait Mode Keyboard - System Panel
     All letter keys wrapped in FrameLayout with corner hint TextView (top-right).
     All letter keys have weight=1, function keys compressed to 0.5.
     Row totals: Row1=10, Row2=10, Row3=10 → letter keys same width across all rows.
     CRITICAL: Letter buttons use elevation="0dp" + stateListAnimator="@null" to prevent
     Material elevation from hiding the sibling corner-hint TextViews. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/Fragment_KeyBoard_System"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/keyboard_outer_padding_top"
    android:paddingVertical="@dimen/keyboard_outer_padding_bottom"
    android:visibility="visible">

    <!-- Row 1: Q W E R T Y U I O P
         10 letters × weight=1 with margins.
         Corner hints show long-press symbols (KeyCMD reference). -->
    <LinearLayout
        android:id="@+id/keyboard_row1"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/keyboard_key_margin_vertical">

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4.75dp" android:layout_marginEnd="1.5dp">
            <android.widget.Button android:id="@+id/Q_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/Q_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/Q_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="!"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="1.5dp">
            <android.widget.Button android:id="@+id/W_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/W_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/W_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="@"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="1.5dp">
            <android.widget.Button android:id="@+id/E_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/E_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/E_Button_hint"
