                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/I_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="*"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="1.5dp">
            <android.widget.Button android:id="@+id/O_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/O_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/O_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text=","/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="1.5dp" android:layout_marginEnd="4.75dp">
            <android.widget.Button android:id="@+id/P_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/P_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/P_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="."/>
        </FrameLayout>
    </LinearLayout>

    <!-- Row 2: Tab(1.2) + A S D F G H J K L(1) + Backspace(1.2), total=11.4
         Corner hints show long-press symbols for letter keys. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/keyboard_key_margin_vertical">

        <android.widget.Button android:id="@+id/Key_Tab"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1.2" android:text="@string/Key_Tab"
            android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
            android:theme="@style/ButtonTheme"
            android:layout_marginStart="0dp" android:layout_marginEnd="@dimen/keyboard_key_margin_horizontal"
            android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
            android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/A_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/A_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/A_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="¥"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/S_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/S_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:autoSizeTextType="uniform" android:autoSizeMinTextSize="5sp"
                android:autoSizeMaxTextSize="12sp" tools:ignore="UnusedAttribute"/>
            <TextView android:id="@+id/S_Button_hint"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:paddingTop="2dp" android:paddingEnd="4dp"
                android:textSize="9sp" android:textColor="@color/text_on_surface"
                android:alpha="0.5" android:includeFontPadding="false"
                android:elevation="1dp"
                android:text="`"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/keyboard_key_margin_horizontal">
            <android.widget.Button android:id="@+id/D_Button"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="@string/D_Button"
                android:textColor="@color/text_on_surface" android:background="@drawable/button_background"
                android:elevation="0dp" android:stateListAnimator="@null"
