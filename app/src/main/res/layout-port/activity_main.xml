<?xml version="1.0" encoding="utf-8"?>
<!-- Portrait Mode Layout: 4-zone design -->
<!-- Zone 1: Shortcut Strip (top)
     Zone 2: Video Stream (center, fills remaining space)
     Zone 3: Module Drawer (hidden by default, overlays bottom of video area)
     Zone 4: Module Selector Bar (bottom) -->
<LinearLayout
    android:id="@+id/thisFrameLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context="com.openterface.AOS.activity.MainActivity"
    android:background="@android:color/black">

    <!-- Zone 1: Shortcut Strip (KeyCMD style) -->
    <LinearLayout
        android:id="@+id/shortcut_strip"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/card_background"
        android:paddingHorizontal="6dp"
        android:gravity="center_vertical">

        <!-- Open shortcut key config Hub (top-left button) -->
        <ImageButton
            android:id="@+id/shortcut_profile_switch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/shortcut_button_background"
            android:src="@drawable/ic_list_24"
            android:scaleType="centerInside"
            android:contentDescription="@string/shortcut_config"
            android:padding="8dp"
            android:tint="@color/key_text" />

        <HorizontalScrollView
            android:id="@+id/shortcut_scroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/shortcut_buttons_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <!-- Shortcut buttons are dynamically generated by Java code -->
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Zone 2: Video Stream Display -->
    <RelativeLayout
        android:id="@+id/video_area_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:background="@color/black">

        <!-- Video preview - centered and preserving aspect ratio -->
        <com.serenegiant.widget.AspectRatioTextureView
            android:id="@+id/viewMainPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:visibility="visible" />

        <ImageView
            android:id="@+id/tvConnectUSBCameraTip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            app:srcCompat="@drawable/content_dark_eng"
            tools:ignore="ContentDescription" />

        <!-- PiP 缩略图容器 - landscape aspect ratio to match video -->
        <RelativeLayout
            android:id="@+id/thumbnail_container"
            android:layout_width="200dp"
            android:layout_height="113dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone"
            android:background="@drawable/pip_background"
            android:elevation="8dp">

            <com.serenegiant.widget.AspectRatioSurfaceView
                android:id="@+id/cameraViewSecond"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <View
                android:id="@+id/view_indicator"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="#6600ff00"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <!-- PiP 拖动按钮 -->
        <ImageButton
            android:id="@+id/drag_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="140dp"
            android:background="@drawable/pip_drag_button"
            android:src="@drawable/three_dots"
            android:visibility="gone"
            android:elevation="9dp"
            android:contentDescription="@string/drag_pip_window"/>

        <!-- Rotation lock button (top-right corner) -->
        <ImageButton
            android:id="@+id/portrait_rotation_lock"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/shortcut_button_background"
            android:src="@drawable/ic_lock_open_24"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="@string/lock_screen_rotation"
            android:elevation="5dp" />
    </RelativeLayout>

    <!-- Zone 3: Module Drawer (below video, not overlay) -->
    <LinearLayout
        android:id="@+id/module_drawer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background_light"
        android:visibility="gone">

        <!-- Module Content Container -->
        <FrameLayout
            android:id="@+id/module_content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
        </FrameLayout>
    </LinearLayout>

    <!-- Zone 4: Module Selector Bar -->
    <LinearLayout
        android:id="@+id/module_selector_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/card_background"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp">

        <LinearLayout
            android:id="@+id/tab_keyboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_keyboard_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/baseline_keyboard_24"
                android:contentDescription="Keyboard" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_keyboard"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_mouse"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_mouse_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/baseline_mouse_24"
                android:contentDescription="Mouse" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_mouse"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_ime"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_ime_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/baseline_keyboard_24"
                android:contentDescription="Input" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_input"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_settings_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/baseline_settings_24"
                android:contentDescription="Settings" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_settings"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
