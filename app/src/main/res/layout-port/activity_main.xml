<?xml version="1.0" encoding="utf-8"?>
<!-- Portrait Mode Layout: 4-zone design -->
<!-- Zone 1: Shortcut Strip (top)
     Zone 2: Video Stream (center, fills remaining space)
     Zone 3: Module Drawer (hidden by default, overlays bottom of video area)
     Zone 4: Module Selector Bar (bottom) -->
<LinearLayout
    android:id="@+id/thisFrameLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context="com.openterface.AOS.activity.MainActivity"
    android:background="@android:color/black">

    <!-- Zone 1: Shortcut Strip (KeyCMD style) -->
    <LinearLayout
        android:id="@+id/shortcut_strip"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/card_background"
        android:paddingHorizontal="6dp"
        android:gravity="center_vertical">

        <!-- 切换快捷键配置 -->
        <ImageButton
            android:id="@+id/shortcut_profile_switch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/shortcut_button_background"
            android:src="@drawable/ic_list_24"
            android:scaleType="centerInside"
            android:contentDescription="切换配置"
            android:padding="8dp"
            android:tint="@color/on_primary" />

        <HorizontalScrollView
            android:id="@+id/shortcut_scroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/shortcut_buttons_container"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/shortcut_esc"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="3dp"
                    android:background="@drawable/shortcut_button_background"
                    android:src="@drawable/baseline_keyboard_24"
                    android:scaleType="centerInside"
                    android:contentDescription="Esc"
                    android:padding="10dp"
                    android:tint="@color/on_primary" />

                <android.widget.Button
                    android:id="@+id/shortcut_ctrl_c"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="3dp"
                    android:text="Ctrl+C"
                    android:textColor="@color/on_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/shortcut_button_background"
                    android:paddingHorizontal="12dp" />

                <android.widget.Button
                    android:id="@+id/shortcut_ctrl_v"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="3dp"
                    android:text="Ctrl+V"
                    android:textColor="@color/on_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/shortcut_button_background"
                    android:paddingHorizontal="12dp" />

                <android.widget.Button
                    android:id="@+id/shortcut_ctrl_a"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="3dp"
                    android:text="Ctrl+A"
                    android:textColor="@color/on_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/shortcut_button_background"
                    android:paddingHorizontal="12dp" />

                <android.widget.Button
                    android:id="@+id/shortcut_ctrl_z"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="3dp"
                    android:text="Ctrl+Z"
                    android:textColor="@color/on_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/shortcut_button_background"
                    android:paddingHorizontal="12dp" />

                <android.widget.Button
                    android:id="@+id/shortcut_ctrl_s"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="3dp"
                    android:text="Ctrl+S"
                    android:textColor="@color/on_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/shortcut_button_background"
                    android:paddingHorizontal="12dp" />

                <ImageButton
                    android:id="@+id/shortcut_keyboard_settings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginHorizontal="3dp"
                    android:background="@drawable/shortcut_button_background"
                    android:src="@drawable/baseline_settings_24"
                    android:scaleType="centerInside"
                    android:contentDescription="键盘设置"
                    android:padding="10dp"
                    android:tint="@color/on_primary" />

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Zone 2: Video Stream Display -->
    <RelativeLayout
        android:id="@+id/video_area_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/black">

        <!-- Video preview - centered and preserving aspect ratio -->
        <com.serenegiant.widget.AspectRatioTextureView
            android:id="@+id/viewMainPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:visibility="invisible" />

        <ImageView
            android:id="@+id/tvConnectUSBCameraTip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            app:srcCompat="@drawable/content_dark_eng"
            tools:ignore="ContentDescription" />
    </RelativeLayout>

    <!-- Zone 3: Module Drawer (below video, not overlay) -->
    <LinearLayout
        android:id="@+id/module_drawer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background_light"
        android:visibility="gone">

        <!-- Module Content Container -->
        <FrameLayout
            android:id="@+id/module_content_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
        </FrameLayout>
    </LinearLayout>

    <!-- Zone 4: Module Selector Bar -->
    <LinearLayout
        android:id="@+id/module_selector_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/card_background"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp">

        <LinearLayout
            android:id="@+id/tab_keyboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_keyboard_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/baseline_keyboard_24"
                android:contentDescription="Keyboard" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="键盘"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_mouse"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_mouse_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/baseline_mouse_24"
                android:contentDescription="Mouse" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="鼠标"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_ime"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_ime_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/baseline_keyboard_24"
                android:contentDescription="Input" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="输入"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_settings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/tab_settings_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/baseline_settings_24"
                android:contentDescription="Settings" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设置"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <android.widget.Button
            android:id="@+id/action_screen_orientation"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:layout_marginStart="2dp"
            android:background="?android:attr/selectableItemBackground"
            android:drawableTop="@drawable/ic_screen_rotation_24"
            android:scaleType="centerInside"
            android:contentDescription="Switch Orientation"
            android:text=""
            android:padding="4dp" />
    </LinearLayout>

</LinearLayout>
