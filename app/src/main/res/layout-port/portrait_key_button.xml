<?xml version="1.0" encoding="utf-8"?>
<!-- Portrait key button with alternate character hint
     Main label centered, small hint text in top-right corner -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/button_background">

    <!-- Main key label -->
    <TextView
        android:id="@+id/key_main_label"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="@color/text_on_surface"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Alternate character hint (top-right corner) -->
    <TextView
        android:id="@+id/key_alternate_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="9sp"
        android:visibility="gone" />

</FrameLayout>
