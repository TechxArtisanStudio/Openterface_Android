<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Usbvideo" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryContainer">@color/key_bg_pressed</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/primary</item>
        <item name="colorOnSecondary">@color/on_primary</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimary</item>
        <!-- Window background -->
        <item name="android:windowBackground">@color/background_light</item>
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/background_light</item>
    </style>

    <style name="ButtonTheme" parent="Theme.AppCompat.Light">
        <item name="android:background">@drawable/key_background</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ButtonStyle" parent="Widget.AppCompat.Button.Colored">
        <item name="android:textColor">#FF000000</item>
        <item name="android:background">@drawable/button_background</item>
    </style>

    <style name="FontStyle" parent="Theme.AppCompat.Light">
        <item name="android:textAllCaps">false</item>
    </style>


    <style name="Theme.Usbvideo.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Fullscreen theme -->
    <style name="Theme.Usbvideo.FullScreen" parent="Theme.Usbvideo.NoActionBar">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.Usbvideo.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.Usbvideo.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

</resources>