<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Usbvideo" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/theme_accent_orange</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/theme_accent_orange_container</item>
        <item name="colorOnPrimaryContainer">@color/theme_accent_orange_on_container</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/theme_accent_orange</item>
        <item name="colorOnSecondary">@color/on_primary</item>
        <item name="colorSecondaryContainer">@color/theme_accent_orange_container</item>
        <item name="colorOnSecondaryContainer">@color/theme_accent_orange_on_container</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimary</item>
        <!-- Window background -->
        <item name="android:windowBackground">@color/background_light</item>
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/background_light</item>
    </style>

