    </style>

    <style name="Theme.Usbvideo.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.Usbvideo.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

